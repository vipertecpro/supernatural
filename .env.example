APP_NAME=Supernatural
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
PUBLIC_SITE_NAME="The Archive"
PUBLIC_SITE_URL=
PUBLIC_REPOSITORY_URL=
PUBLIC_SITE_COMMERCIAL=false
TMDB_API_READ_TOKEN=
TMDB_TV_SERIES_ID=
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_TERMS_ACCEPTED=false
TMDB_COMMERCIAL_LICENSED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# API and browser authentication
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_TOKEN_PREFIX=
PASSKEYS_USER_HANDLE_SECRET=
API_RATE_LIMIT_PER_MINUTE=60
API_PUBLIC_RATE_LIMIT_PER_MINUTE=30
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Queues and broadcasting
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=null

# Reverb server and application (enable only after generating local credentials)
REVERB_SERVER=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
REVERB_SCALING_ENABLED=false
REVERB_APP_ACCEPT_CLIENT_EVENTS_FROM=none
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_APP_RATE_LIMIT_TERMINATE=false

# Octane and FrankenPHP
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false

# Storage
FILESYSTEM_DISK=local

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUBLIC_SITE_NAME="${PUBLIC_SITE_NAME}"
VITE_REVERB_ENABLED=false
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Future content-provider variables must be added only with a configured integration.
